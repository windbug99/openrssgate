NEXT_PUBLIC_API_BASE_URL=https://your-railway-api-domain.up.railway.app/v1

# Server-side only — used by the /api/v1 proxy route on the Vercel frontend.
# Set this to the internal Railway URL (same value as NEXT_PUBLIC_API_BASE_URL but without browser exposure).
# Claude.ai web_fetch and other external clients can then call https://openrssgate.vercel.app/api/v1/...
API_BASE_URL=https://your-railway-api-domain.up.railway.app/v1
